    "s04": "npx tsx agents/s04_bash_security.ts",
    "s05": "npx tsx agents/s05_permissions.ts",
    "s06": "npx tsx agents/s06_context_compact.ts",
    "s07": "npx tsx agents/s07_mcp_protocol.ts",
    "s08": "npx tsx agents/s08_plugin_loader.ts",
    "s09": "npx tsx agents/s09_multi_agent.ts",
    "s10": "npx tsx agents/s10_transport.ts",
    "s11": "npx tsx agents/s11_bootstrap.ts",
